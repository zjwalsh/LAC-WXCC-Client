{
    "name": "tsforms-client",
    "version": "1.0.0",
    "description": "React frontend for TSForms application",
    "private": true,
    "homepage": "/",
    "dependencies": {
        "@wxcc-desktop/sdk": "^2.0.11",
        "@wxcc-desktop/sdk-types": "^1.0.28",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-scripts": "^5.0.1"
    },
    "scripts": {
        "start": "PORT=8443 react-scripts start",
        "build": "react-scripts build",
        "serve": "npx serve -s build -l 8443 --cors",
        "test": "react-scripts test",
        "eject": "react-scripts eject"
    },
    "eslintConfig": {
        "extends": [
            "react-app"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "autoprefixer": "^10.4.17",
        "baseline-browser-mapping": "^2.9.6",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.0"
    }
}
